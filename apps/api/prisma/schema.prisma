generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                 String                @id @default(uuid())
  email              String                @unique
  phone              String?               @unique
  passwordHash       String
  name               String
  role               UserRole
  accountType        AccountType
  orgId              String?
  isActive           Boolean               @default(true)
  lastLoginAt        DateTime?
  createdAt          DateTime              @default(now())
  updatedAt          DateTime              @updatedAt
  createdById        String?
  calories           CalorieLog[]
  goalsAssigned      Goal[]                @relation("GoalAssignedBy")
  goals              Goal[]
  healthMetrics      HealthMetric[]
  memberSub          MemberSubscription?
  ownedOrg           Organization?         @relation("OrgOwner")
  personalSub        PersonalSubscription?
  refreshTokens      RefreshToken[]
  assignedToTrainer  TrainerAssignment[]   @relation("MemberAssignment")
  trainerAssignments TrainerAssignment[]   @relation("TrainerAssignment")
  createdBy          User?                 @relation("UserCreatedBy", fields: [createdById], references: [id])
  createdMembers     User[]                @relation("UserCreatedBy")
  org                Organization?         @relation("OrgMembers", fields: [orgId], references: [id])
  profile            UserProfile?
  workouts           WorkoutLog[]

  @@index([orgId])
  @@index([email])
  @@index([role])
  @@index([createdById])
}

model UserProfile {
  id              String    @id @default(uuid())
  userId          String    @unique
  age             Int?
  gender          String?
  dateOfBirth     DateTime?
  heightCm        Decimal?  @db.Decimal(5, 2)
  currentWeightKg Decimal?  @db.Decimal(5, 2)
  fitnessLevel    String?
  primaryGoal     String?
  medicalNotes    String?
  profilePicUrl   String?
  timezone        String    @default("Asia/Kolkata")
  language        String    @default("en")
  weightUnit      String    @default("kg")
  streakDays      Int       @default(0)
  streakLastDate  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Organization {
  id                 String               @id @default(uuid())
  name               String
  ownerId            String               @unique
  description        String?
  logoUrl            String?
  address            String?
  phone              String?
  email              String?
  timezone           String               @default("Asia/Kolkata")
  currency           String               @default("INR")
  isActive           Boolean              @default(true)
  createdAt          DateTime             @default(now())
  updatedAt          DateTime             @updatedAt
  memberSubs         MemberSubscription[]
  notifications      Notification[]
  owner              User                 @relation("OrgOwner", fields: [ownerId], references: [id])
  subscriptionPlans  SubscriptionPlan[]
  trainerAssignments TrainerAssignment[]
  members            User[]               @relation("OrgMembers")

  @@index([ownerId])
}

model RefreshToken {
  id        String    @id @default(uuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

model SubscriptionPlan {
  id             String               @id @default(uuid())
  orgId          String
  name           String
  description    String?
  priceInr       Decimal              @db.Decimal(10, 2)
  durationDays   Int
  features       Json
  memberCapacity Int?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt
  subscriptions  MemberSubscription[]
  org            Organization         @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId])
}

model MemberSubscription {
  id            String             @id @default(uuid())
  memberId      String             @unique
  orgId         String
  planId        String
  startedAt     DateTime           @default(now())
  expiresAt     DateTime
  status        SubscriptionStatus @default(ACTIVE)
  amountPaidInr Decimal            @db.Decimal(10, 2)
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  member        User               @relation(fields: [memberId], references: [id], onDelete: Cascade)
  org           Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  plan          SubscriptionPlan   @relation(fields: [planId], references: [id])

  @@index([orgId])
  @@index([memberId])
  @@index([expiresAt])
}

model PersonalSubscription {
  id               String             @id @default(uuid())
  userId           String             @unique
  tier             PersonalTier       @default(TRIAL)
  trialStartedAt   DateTime?
  trialEndsAt      DateTime?
  premiumStartedAt DateTime?
  premiumEndsAt    DateTime?
  status           SubscriptionStatus @default(TRIAL)
  autoRenew        Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  user             User               @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model WorkoutLog {
  id             String            @id @default(uuid())
  userId         String
  orgId          String?
  loggedDate     DateTime
  workoutType    WorkoutType
  durationMin    Int
  intensity      Intensity
  caloriesBurned Int?
  notes          String?
  // Optional reference if this workout was built from a routine
  routineId      String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  exercises      WorkoutExercise[]
  user           User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  routine        Routine?          @relation(fields: [routineId], references: [id], onDelete: SetNull)

  @@index([userId, loggedDate])
  @@index([orgId])
}

model WorkoutExercise {
  id           String       @id @default(uuid())
  workoutLogId String
  exerciseId   String? // optional FK to canonical exercise
  exerciseName String // denormalized snapshot
  orderIndex   Int          @default(0) // ordering within workout
  notes        String?
  workout      WorkoutLog   @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)
  exercise     Exercise?    @relation(fields: [exerciseId], references: [id], onDelete: SetNull)
  sets         WorkoutSet[]

  @@index([workoutLogId])
  @@index([exerciseId])
}

// One row per set. Strong/Hevy pattern.
model WorkoutSet {
  id                  String          @id @default(uuid())
  workoutExerciseId   String
  setIndex            Int // 1, 2, 3...
  // Strength: weight × reps. Cardio: time/distance. Bodyweight: reps only.
  reps                Int?
  weightKg            Decimal?        @db.Decimal(6, 2)
  distanceKm          Decimal?        @db.Decimal(6, 2)
  timeSeconds         Int?
  rpe                 Int? // perceived exertion 1-10
  isWarmup            Boolean         @default(false)
  isPR                Boolean         @default(false) // personal record flag
  notes               String?
  createdAt           DateTime        @default(now())
  exerciseEntry       WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId])
}

// Canonical exercise library (seed + AI-cached + user-custom)
model Exercise {
  id               String           @id @default(uuid())
  name             String
  nameLocal        String?
  category         ExerciseCategory
  primaryMuscles   Json // ["chest", "triceps"]
  secondaryMuscles Json?
  equipment        String?  // barbell | dumbbell | machine | bodyweight | cable | kettlebell
  defaultUnit      String           @default("REPS") // REPS | TIME | DISTANCE
  metPerKg         Decimal?         @db.Decimal(4, 2)
  description      String?
  isCustom         Boolean          @default(false)
  createdByUserId  String?
  source           ExerciseSource   @default(MANUAL)
  isVerified       Boolean          @default(false)
  searchKey        String?
  usageCount       Int              @default(0)
  createdAt        DateTime         @default(now())

  workoutEntries   WorkoutExercise[]

  @@index([name])
  @@index([category])
  @@index([searchKey])
  @@index([usageCount(sort: Desc)])
}

// User-saved templates ("Push day", "Leg day"). Self-improving via usage.
model Routine {
  id          String            @id @default(uuid())
  userId      String
  name        String
  description String?
  // Auto-generated from history: true if AI/system created it
  isSuggested Boolean           @default(false)
  usageCount  Int               @default(0) // how many times user did this routine
  lastUsedAt  DateTime?
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  exercises   RoutineExercise[]
  workouts    WorkoutLog[]

  @@index([userId, lastUsedAt(sort: Desc)])
}

model RoutineExercise {
  id          String   @id @default(uuid())
  routineId   String
  exerciseId  String?
  exerciseName String  // denormalized snapshot
  orderIndex  Int      @default(0)
  // Default set scheme: "3x8-12" or "5x5" — free text for flexibility
  setScheme   String?
  notes       String?
  routine     Routine  @relation(fields: [routineId], references: [id], onDelete: Cascade)

  @@index([routineId])
}

model FoodItem {
  id              String     @id @default(uuid())
  name            String
  nameLocal       String?
  category        String?
  servingSize     String
  caloriesPer100g Decimal    @db.Decimal(7, 2)
  proteinG        Decimal    @db.Decimal(5, 2)
  carbsG          Decimal    @db.Decimal(5, 2)
  fatG            Decimal    @db.Decimal(5, 2)
  fiberG          Decimal?   @db.Decimal(5, 2)
  isCustom        Boolean    @default(false)
  createdByUserId String?
  isIndian        Boolean    @default(true)
  source          FoodSource @default(MANUAL)
  isVerified      Boolean    @default(false)
  searchKey       String?
  usageCount      Int        @default(0)
  createdAt       DateTime   @default(now())

  @@index([name])
  @@index([category])
  @@index([searchKey])
  @@index([usageCount(sort: Desc)])
}

model CalorieLog {
  id          String   @id @default(uuid())
  userId      String
  orgId       String?
  loggedDate  DateTime
  mealType    MealType
  foodName    String
  servingSize String
  calories    Decimal  @db.Decimal(7, 2)
  proteinG    Decimal  @db.Decimal(5, 2)
  carbsG      Decimal  @db.Decimal(5, 2)
  fatG        Decimal  @db.Decimal(5, 2)
  fiberG      Decimal? @db.Decimal(5, 2)
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, loggedDate])
  @@index([orgId])
}

model Goal {
  id            String     @id @default(uuid())
  userId        String
  orgId         String?
  goalType      GoalType
  targetValue   Decimal    @db.Decimal(7, 2)
  targetUnit    String
  startingValue Decimal    @db.Decimal(7, 2)
  targetDate    DateTime
  status        GoalStatus @default(ACTIVE)
  reason        String?
  assignedById  String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  completedAt   DateTime?
  assignedBy    User?      @relation("GoalAssignedBy", fields: [assignedById], references: [id])
  user          User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([orgId])
}

model HealthMetric {
  id         String   @id @default(uuid())
  userId     String
  orgId      String?
  metricDate DateTime
  weightKg   Decimal? @db.Decimal(5, 2)
  bmi        Decimal? @db.Decimal(4, 2)
  chestCm    Decimal? @db.Decimal(5, 2)
  waistCm    Decimal? @db.Decimal(5, 2)
  hipsCm     Decimal? @db.Decimal(5, 2)
  notes      String?
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, metricDate])
}

model TrainerAssignment {
  id         String       @id @default(uuid())
  trainerId  String
  memberId   String
  orgId      String
  isActive   Boolean      @default(true)
  assignedAt DateTime     @default(now())
  member     User         @relation("MemberAssignment", fields: [memberId], references: [id], onDelete: Cascade)
  org        Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  trainer    User         @relation("TrainerAssignment", fields: [trainerId], references: [id], onDelete: Cascade)

  @@unique([trainerId, memberId])
  @@index([orgId])
}

model Notification {
  id            String              @id @default(uuid())
  orgId         String
  templateName  String?
  recipientIds  Json
  messageText   String
  channel       NotificationChannel
  scheduledFor  DateTime?
  sentAt        DateTime?
  status        NotificationStatus  @default(PENDING)
  failureReason String?
  whatsappMsgId String?
  createdAt     DateTime            @default(now())
  org           Organization        @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@index([orgId, status])
  @@index([scheduledFor])
}

model AuditLog {
  id         String   @id @default(uuid())
  userId     String?
  orgId      String?
  action     String
  entityType String?
  entityId   String?
  metadata   Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([orgId])
  @@index([action])
  @@index([createdAt])
}

enum UserRole {
  MASTER_ADMIN
  ORG_OWNER
  TRAINER
  ORG_MEMBER
  INDIVIDUAL_USER
}

enum AccountType {
  B2B
  B2C
}

enum SubscriptionStatus {
  ACTIVE
  TRIAL
  EXPIRING
  EXPIRED
  CANCELLED
}

enum PersonalTier {
  FREE
  TRIAL
  PREMIUM
}

enum WorkoutType {
  CARDIO
  STRENGTH
  FLEXIBILITY
  SPORTS
  OTHER
}

enum Intensity {
  LIGHT
  MODERATE
  HIGH
}

enum MealType {
  BREAKFAST
  LUNCH
  SNACKS
  DINNER
}

enum GoalType {
  LOSE_WEIGHT
  GAIN_MUSCLE
  BUILD_ENDURANCE
  IMPROVE_FLEXIBILITY
  CUSTOM
}

enum GoalStatus {
  ACTIVE
  PAUSED
  COMPLETED
  ABANDONED
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  WHATSAPP
}

enum NotificationStatus {
  PENDING
  SCHEDULED
  SENT
  FAILED
}

enum FoodSource {
  MANUAL
  USER_CUSTOM
  AI_GENERATED
}

enum ExerciseSource {
  MANUAL
  USER_CUSTOM
  AI_GENERATED
}

enum ExerciseCategory {
  STRENGTH
  CARDIO
  FLEXIBILITY
  SPORTS
  BODYWEIGHT
  OTHER
}
